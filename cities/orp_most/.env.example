# ── Registry ────────────────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── Ports ───────────────────────────────────────────────────────────────────
API_PORT=8000
TRAFFIC_BACKEND_PORT=8081
ADMIN_BACKEND_PORT=8082
UI_PORT=80

# ── Central DB (zdieľaná, beží raz na serveri) ──────────────────────────────
# Premenné sú rovnaké ako v db/centralDbCreation/.env
CENTRAL_DB_HOST=db_central          # container name ak na rovnakej sieti, inak IP
CENTRAL_DB_PORT=5432
POSTGRES_DB_CENTRAL=central_db
POSTGRES_USER_CENTRAL=db
POSTGRES_PASSWORD_CENTRAL=
