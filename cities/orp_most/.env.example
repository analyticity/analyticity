# ════════════════════════════════════════════════════════════════════════════
#  Analyticity — ORP Most
#  Copy to .env and fill in all values. .env is gitignored.
# ════════════════════════════════════════════════════════════════════════════

# ── Registry / image tag ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── Host ports ───────────────────────────────────────────────────────────────
API_PORT=8000
TRAFFIC_BACKEND_PORT=8081
ADMIN_BACKEND_PORT=8082
UI_PORT=80

# ── CORS origins ──────────────────────────────────────────────────────────────
ORIGINS=http://localhost:5173

# ── Central DB  (zdieľaná, musí súhlasiť s db/centralDbCreation/.env) ────────
DB_CENTRAL_HOST=db_central
DB_CENTRAL_PORT=5432
DB_CENTRAL_NAME=central_db
DB_CENTRAL_USER=db
DB_CENTRAL_PASSWORD=

# ── City-local DB  (ORP Most) ─────────────────────────────────────────────────
POSTGRES_HOST_BRNO=local_db         # premenná sa volá _BRNO aj pre iné mestá (historický artefakt v zdrojáku)
POSTGRES_PORT_BRNO=5432
POSTGRES_DB_BRNO=analyticity
POSTGRES_USER_BRNO=postgres
POSTGRES_PASSWORD_BRNO=

# ── TrafficJamsBackend ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:FILLME@local_db:5432/analyticity
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:FILLME@local_db:5432/analyticity
DATA_SOURCE=postgres
DBSCAN_EPS_METERS=100.0
DBSCAN_MIN_SAMPLES=3
AUTO_CLUSTER_ON_STARTUP=false
MODELS_DIR=models
WORKERS=2

# ── AdminBackend  (JWT) ───────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RECIPIENT=

# ── Bounding box — ORP Most (Ústecký kraj) ────────────────────────────────────
# Covers: Most, Litvínov, Meziboří and surrounding ORP municipalities
BBOX_MIN_LON=13.35
BBOX_MIN_LAT=50.43
BBOX_MAX_LON=13.82
BBOX_MAX_LAT=50.68
OSM_BBOX=13.35,50.43,13.82,50.68