# ════════════════════════════════════════════════════════════════════════════
#  Analyticity — ORP Most
#  Copy to .env and fill in all values. .env is gitignored — never commit.
# ════════════════════════════════════════════════════════════════════════════

# ── Registry / image tag ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── App host ports  (iné ako Brno — obe mestá môžu bežať súčasne) ────────────
API_PORT=8101
TRAFFIC_BACKEND_PORT=8102
ADMIN_BACKEND_PORT=8103
UI_PORT=8100

# ── Infra host ports  (+100 oproti Brno) ──────────────────────────────────────
POSTGRES_TIMESCALE_PORT=5532
REDPANDA_SCHEMA_EXT_PORT=18181
REDPANDA_PROXY_EXT_PORT=18182
REDPANDA_KAFKA_EXT_PORT=19192
REDPANDA_METRICS_EXT_PORT=19744
PGADMIN_INFRA_PORT=5150
CONSOLE_EXT_PORT=8180
NDIC_EXT_PORT=8988
POLICE_EXT_PORT=9799
ACCIDENTS_TRANSFORMER_EXT_PORT=9798
JAMS_TRANSFORMER_EXT_PORT=9797
ALERTS_TRANSFORMER_EXT_PORT=9796
CLOSURES_TRANSFORMER_EXT_PORT=9795
EVENT_LINKER_EXT_PORT=9794
OTEL_GRPC_PORT=4417
OTEL_HTTP_PORT=4418
JAEGER_UI_PORT=16786
PROMETHEUS_PORT=9190
GRAFANA_PORT=3100

# ── CORS origins ──────────────────────────────────────────────────────────────
ORIGINS=http://localhost:8100

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8101/api/v1
# Stred = (MIN+MAX)/2 z bounding boxu
VITE_APP_CENTER_LON=13.585
VITE_APP_CENTER_LAT=50.555
VITE_APP_CITY=ORP Most

# ── Central DB  (zdieľaná, musí súhlasiť s db/centralDbCreation/.env) ────────
DB_CENTRAL_HOST=db_central
DB_CENTRAL_PORT=5432
DB_CENTRAL_NAME=central_db
DB_CENTRAL_USER=db
DB_CENTRAL_PASSWORD=

# ── City-local DB  (ORP Most — postgres-timescale z infrastructure stack) ─────
# Premenná sa volá _BRNO aj pre iné mestá (historický artefakt v zdrojáku)
POSTGRES_HOST_BRNO=postgres-timescale
POSTGRES_PORT_BRNO=5432
POSTGRES_DB_BRNO=traffic
POSTGRES_USER_BRNO=traffic
POSTGRES_PASSWORD_BRNO=

# ── TrafficJamsBackend ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://traffic:FILLME@postgres-timescale:5432/traffic
DATABASE_URL_SYNC=postgresql+psycopg2://traffic:FILLME@postgres-timescale:5432/traffic
DATA_SOURCE=postgres
DBSCAN_EPS_METERS=100.0
DBSCAN_MIN_SAMPLES=3
AUTO_CLUSTER_ON_STARTUP=false
MODELS_DIR=models
WORKERS=1

# ── AdminBackend  (JWT) ───────────────────────────────────────────────────────
SECRET_KEY=                         # vygeneruj: openssl rand -hex 64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RECIPIENT=

# ════════════════════════════════════════════════════════════════════════════
#  Data model stack  (TimescaleDB + Redpanda + extractors)
# ════════════════════════════════════════════════════════════════════════════

POSTGRES_DB=traffic
POSTGRES_USER=traffic
POSTGRES_PASSWORD=

KAFKA_BROKERS=redpanda:9092
TOPIC_JAMS=raw.waze.jams
TOPIC_ALERTS=raw.waze.alerts
TOPIC_IRREGULARS=raw.waze.irregularities
TOPIC_CLOSURES=raw.ndic.closures
TOPIC_ACCIDENTS=raw.police.accidents

WAZE_URL=
WAZE_FETCH_SECONDS=60s

POLICE_BASE_URL=https://policie.gov.cz/clanek/statistika-nehodovosti-900835.aspx
POLICE_REGION=ULK
POLICE_START_YEAR=2016
POLICE_FETCH_INTERVAL=24h

NDIC_USER=
NDIC_PASS=

# Covers: Most, Litvínov, Meziboří and surrounding ORP municipalities
BBOX_MIN_LON=13.35
BBOX_MIN_LAT=50.43
BBOX_MAX_LON=13.82
BBOX_MAX_LAT=50.68
OSM_BBOX=13.35,50.43,13.82,50.68

RUN_SEEDS=true
RUN_OSM_IMPORT=true
LINKER_INTERVAL=2m
LINKER_INITIAL_DELAY=30s
OTEL_DISABLED=true
OTEL_EXPORTER=http://otel-collector:4317
