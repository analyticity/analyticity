# ════════════════════════════════════════════════════════════════════════════
#  Analyticity — Brno
#  Copy to .env and fill in all values. .env is gitignored — never commit.
# ════════════════════════════════════════════════════════════════════════════

# ── Registry / image tag ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── App host ports ────────────────────────────────────────────────────────────
API_PORT=8000
TRAFFIC_BACKEND_PORT=8081
ADMIN_BACKEND_PORT=8082
UI_PORT=80

# ── Infra host ports  (Brno = defaults, ORP Most používa +100 offset) ────────
POSTGRES_TIMESCALE_PORT=5432
REDPANDA_SCHEMA_EXT_PORT=18081
REDPANDA_PROXY_EXT_PORT=18082
REDPANDA_KAFKA_EXT_PORT=19092
REDPANDA_METRICS_EXT_PORT=19644
PGADMIN_INFRA_PORT=5050
CONSOLE_EXT_PORT=8080
NDIC_EXT_PORT=8888
POLICE_EXT_PORT=9999
ACCIDENTS_TRANSFORMER_EXT_PORT=9998
JAMS_TRANSFORMER_EXT_PORT=9997
ALERTS_TRANSFORMER_EXT_PORT=9996
CLOSURES_TRANSFORMER_EXT_PORT=9995
EVENT_LINKER_EXT_PORT=9994
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
JAEGER_UI_PORT=16686
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── CORS origins ──────────────────────────────────────────────────────────────
ORIGINS=http://localhost

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
VITE_APP_CENTER_LON=16.6
VITE_APP_CENTER_LAT=49.2
VITE_APP_CITY=Brno

# ── Central DB  (zdieľaná, musí súhlasiť s db/centralDbCreation/.env) ────────
DB_CENTRAL_HOST=db_central
DB_CENTRAL_PORT=5432
DB_CENTRAL_NAME=central_db
DB_CENTRAL_USER=db
DB_CENTRAL_PASSWORD=

# ── City-local DB  (Brno — postgres-timescale z infrastructure stack) ─────────
POSTGRES_HOST_BRNO=postgres-timescale
POSTGRES_PORT_BRNO=5432
POSTGRES_DB_BRNO=traffic
POSTGRES_USER_BRNO=traffic
POSTGRES_PASSWORD_BRNO=

# ── TrafficJamsBackend ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://traffic:FILLME@postgres-timescale:5432/traffic
DATABASE_URL_SYNC=postgresql+psycopg2://traffic:FILLME@postgres-timescale:5432/traffic
DATA_SOURCE=postgres
DBSCAN_EPS_METERS=100.0
DBSCAN_MIN_SAMPLES=3
AUTO_CLUSTER_ON_STARTUP=false
MODELS_DIR=models
WORKERS=1

# ── AdminBackend  (JWT) ───────────────────────────────────────────────────────
SECRET_KEY=                         # vygeneruj: openssl rand -hex 64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RECIPIENT=

# ════════════════════════════════════════════════════════════════════════════
#  Data model stack  (TimescaleDB + Redpanda + extractors)
# ════════════════════════════════════════════════════════════════════════════

POSTGRES_DB=traffic
POSTGRES_USER=traffic
POSTGRES_PASSWORD=

KAFKA_BROKERS=redpanda:9092
TOPIC_JAMS=raw.waze.jams
TOPIC_ALERTS=raw.waze.alerts
TOPIC_IRREGULARS=raw.waze.irregularities
TOPIC_CLOSURES=raw.ndic.closures
TOPIC_ACCIDENTS=raw.police.accidents

WAZE_URL=
WAZE_FETCH_SECONDS=60s

POLICE_BASE_URL=https://policie.gov.cz/clanek/statistika-nehodovosti-900835.aspx
POLICE_REGION=JHM
POLICE_START_YEAR=2016
POLICE_FETCH_INTERVAL=24h

NDIC_USER=
NDIC_PASS=

BBOX_MIN_LON=16.4
BBOX_MIN_LAT=49.1
BBOX_MAX_LON=16.8
BBOX_MAX_LAT=49.3
OSM_BBOX=16.4,49.1,16.8,49.3

RUN_SEEDS=true
RUN_OSM_IMPORT=true
LINKER_INTERVAL=2m
LINKER_INITIAL_DELAY=30s
OTEL_DISABLED=true
OTEL_EXPORTER=http://otel-collector:4317
