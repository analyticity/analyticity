# ════════════════════════════════════════════════════════════════════════════
#  Analyticity — Brno
#  Copy to .env and fill in all values. .env is gitignored.
# ════════════════════════════════════════════════════════════════════════════

# ── Registry / image tag ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── Host ports ───────────────────────────────────────────────────────────────
API_PORT=8000
TRAFFIC_BACKEND_PORT=8081
ADMIN_BACKEND_PORT=8082
UI_PORT=80

# ── CORS origins ──────────────────────────────────────────────────────────────
ORIGINS=http://localhost:5173

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ── Central DB  (zdieľaná, musí súhlasiť s db/centralDbCreation/.env) ────────
DB_CENTRAL_HOST=db_central
DB_CENTRAL_PORT=5432
DB_CENTRAL_NAME=central_db
DB_CENTRAL_USER=db
DB_CENTRAL_PASSWORD=

# ── City-local DB  (Brno) ─────────────────────────────────────────────────────
POSTGRES_HOST_BRNO=local_db
POSTGRES_PORT_BRNO=5432
POSTGRES_DB_BRNO=analyticity
POSTGRES_USER_BRNO=postgres
POSTGRES_PASSWORD_BRNO=

# ── TrafficJamsBackend ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:FILLME@local_db:5432/analyticity
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:FILLME@local_db:5432/analyticity
DATA_SOURCE=postgres
DBSCAN_EPS_METERS=100.0
DBSCAN_MIN_SAMPLES=3
AUTO_CLUSTER_ON_STARTUP=false
MODELS_DIR=models
WORKERS=2

# ── AdminBackend  (JWT) ───────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RECIPIENT=

# ════════════════════════════════════════════════════════════════════════════
#  Data model stack  (TimescaleDB + Redpanda + extractors)
# ════════════════════════════════════════════════════════════════════════════

POSTGRES_DB=traffic
POSTGRES_USER=traffic
POSTGRES_PASSWORD=

KAFKA_BROKERS=redpanda:9092
TOPIC_JAMS=raw.waze.jams
TOPIC_ALERTS=raw.waze.alerts
TOPIC_IRREGULARS=raw.waze.irregularities
TOPIC_CLOSURES=raw.ndic.closures
TOPIC_ACCIDENTS=raw.police.accidents

WAZE_URL=
WAZE_FETCH_SECONDS=60s

POLICE_BASE_URL=https://policie.gov.cz/clanek/statistika-nehodovosti-900835.aspx
POLICE_REGION=JHM
POLICE_START_YEAR=2016
POLICE_FETCH_INTERVAL=24h

NDIC_USER=
NDIC_PASS=

BBOX_MIN_LON=16.4
BBOX_MIN_LAT=49.1
BBOX_MAX_LON=16.8
BBOX_MAX_LAT=49.3
OSM_BBOX=16.4,49.1,16.8,49.3

RUN_SEEDS=true
RUN_OSM_IMPORT=true
LINKER_INTERVAL=2m
LINKER_INITIAL_DELAY=30s
OTEL_DISABLED=true
OTEL_EXPORTER=http://otel-collector:4317
