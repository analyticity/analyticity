# ════════════════════════════════════════════════════════════════════════════
#  Analyticity — city .env template
#  Copy this file to .env in your city folder and fill in all values.
#  .env is gitignored and must NEVER be committed.
# ════════════════════════════════════════════════════════════════════════════

# ── Registry / image tag ─────────────────────────────────────────────────────
REGISTRY=ghcr.io/analyticity
IMAGE_TAG=latest

# ── Host ports  (zmeň ak kolidujú s inou aplikáciou na tomto serveri) ────────
API_PORT=8000
TRAFFIC_BACKEND_PORT=8081
ADMIN_BACKEND_PORT=8082
UI_PORT=80

# ── CORS origins  (URL frontendu prístupná z prehliadača) ────────────────────
ORIGINS=http://localhost:5173

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ── Central DB  (zdieľaná inštancia, beží raz pre všetky mestá) ──────────────
# Hodnoty musia súhlasiť s db/centralDbCreation/.env
DB_CENTRAL_HOST=db_central          # container name ak na rovnakej sieti, inak IP servera
DB_CENTRAL_PORT=5432
DB_CENTRAL_NAME=central_db
DB_CENTRAL_USER=db
DB_CENTRAL_PASSWORD=

# ── City-local DB  (lokálna DB pre dané mesto — API + TrafficJams) ───────────
# Každé mesto má vlastnú inštanciu
POSTGRES_HOST_BRNO=local_db         # container name v rámci docker-compose mesta
POSTGRES_PORT_BRNO=5432
POSTGRES_DB_BRNO=analyticity
POSTGRES_USER_BRNO=postgres
POSTGRES_PASSWORD_BRNO=

# ── TrafficJamsBackend  (connection strings pre city-local DB) ────────────────
DATABASE_URL=postgresql+asyncpg://postgres:FILLME@local_db:5432/analyticity
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:FILLME@local_db:5432/analyticity
DATA_SOURCE=postgres
DBSCAN_EPS_METERS=100.0
DBSCAN_MIN_SAMPLES=3
AUTO_CLUSTER_ON_STARTUP=false
MODELS_DIR=models
WORKERS=2

# ── AdminBackend  (JWT) ───────────────────────────────────────────────────────
SECRET_KEY=                         # vygeneruj: openssl rand -hex 64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email  (SMTP pre notifikácie) ─────────────────────────────────────────────
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RECIPIENT=

# ════════════════════════════════════════════════════════════════════════════
#  Data model stack  (sources/data_model — TimescaleDB + Redpanda + extractors)
#  Spúšťa sa cez: ./analyticity.sh data:up <city> [profile]
# ════════════════════════════════════════════════════════════════════════════

# ── TimescaleDB  (city-local, spravovaná data stackom) ───────────────────────
POSTGRES_DB=traffic
POSTGRES_USER=traffic
POSTGRES_PASSWORD=

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BROKERS=redpanda:9092
TOPIC_JAMS=raw.waze.jams
TOPIC_ALERTS=raw.waze.alerts
TOPIC_IRREGULARS=raw.waze.irregularities
TOPIC_CLOSURES=raw.ndic.closures
TOPIC_ACCIDENTS=raw.police.accidents

# ── Waze Feed  (city-specific URL z Waze Partner Hub) ────────────────────────
WAZE_URL=
WAZE_FETCH_SECONDS=60s

# ── Police Accidents ──────────────────────────────────────────────────────────
POLICE_BASE_URL=https://policie.gov.cz/clanek/statistika-nehodovosti-900835.aspx
POLICE_REGION=                      # napr. JHM, STC, PLK ...
POLICE_START_YEAR=2016
POLICE_FETCH_INTERVAL=24h

# ── NDIC Closures ─────────────────────────────────────────────────────────────
NDIC_USER=
NDIC_PASS=

# ── Geographic bounding box  (pre filtrovanie dát na územie mesta) ────────────
BBOX_MIN_LON=
BBOX_MIN_LAT=
BBOX_MAX_LON=
BBOX_MAX_LAT=
OSM_BBOX=                           # formát: "min_lon,min_lat,max_lon,max_lat"

# ── DB migrate ────────────────────────────────────────────────────────────────
RUN_SEEDS=true
RUN_OSM_IMPORT=true

# ── Event linker ──────────────────────────────────────────────────────────────
LINKER_INTERVAL=2m
LINKER_INITIAL_DELAY=30s

# ── Telemetria  (OTEL — zapni profilom mon) ───────────────────────────────────
OTEL_DISABLED=true
OTEL_EXPORTER=http://otel-collector:4317
